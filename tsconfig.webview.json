{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": ["vite/client"],
    "rootDir": "./src",
    "noEmit": true
  },
  "include": ["src/webview-cockpit/**/*"],
  "exclude": ["node_modules", "dist", "out", ".vscode-test"]
}
